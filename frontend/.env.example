# MultiversX Marketplace — Frontend Environment Variables
# Copy this file to .env and fill in your values

# Network: devnet | testnet | mainnet
REACT_APP_NETWORK=devnet

# Your deployed marketplace smart contract address
REACT_APP_CONTRACT_ADDRESS=erd1qqqqqqqqqqqqqpgqmzpauhqppu707208j8zrjq8q7trpgw7yvhuqtjt9ev

# MoonPay API Key (optional — for fiat on-ramp)
REACT_APP_MOONPAY_API_KEY=your_moonpay_api_key_here

# AWS Lambda webhook URL (optional — for fiat escrow notifications)
REACT_APP_WEBHOOK_URL=

# Backend API URL (optional — for dynamic competition data, analytics, etc.)
# Leave empty to use static JSON files (works with GitHub Pages)
# REACT_APP_API_URL=https://your-api-domain.com
